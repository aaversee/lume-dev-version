# Copy to `.env` and change values.

# REQUIRED: secret used for issuing/verifying WebSocket JWT tokens.
# Must be at least 32 bytes (long random string).
WS_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES

# OPTIONAL
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
# Set to 1 only when running behind a trusted reverse proxy (Fly, Vercel, Nginx, etc.).
TRUST_PROXY=0
# Comma-separated allowlist. Example:
# CLIENT_ORIGIN=https://lume.example.com,https://www.lume.example.com
CLIENT_ORIGIN=http://localhost:3000
# Max JSON request body size. Default 8mb so base64-encoded file uploads fit (files capped at 5 MB raw).
JSON_LIMIT=8mb
WS_MAX_PAYLOAD_BYTES=65536

# Set to 1 to enable per-request logging (noisy in production).
LOG_HTTP=0
# Set to 1 to enable security-related logs (audit/debug).
LOG_SECURITY=0

# If running behind a reverse proxy, enable to trust `X-Forwarded-For` etc.
WS_TRUST_PROXY=0

# Development only: force-close WS connections with a specific close code.
# WS_DEV_FORCE_CLOSE_CODE=

# Required in production to expose GET /api/metrics. If unset, metrics is disabled (403) in production.
# METRICS_SECRET=generate-a-long-random-string

# Web Push (VAPID). Optional — only needed if push notifications are enabled.
# Generate a key pair with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Optional explicit DB path (default resolves to ./data/messenger.db).
# DB_PATH=/app/data/messenger.db
